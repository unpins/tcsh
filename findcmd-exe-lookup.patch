+#ifdef __COSMOCC__
+/*
+ * On Cosmopolitan/Windows hosts an installed program is named "foo.exe", but
+ * users (and scripts) type the bare "foo".  When the path tcsh is about to
+ * exec does not already end in ".exe", return a freshly-allocated copy with
+ * ".exe" appended so the caller can retry the exec; otherwise return NULL.
+ * The result must be released with xfree().  Uses only tcsh Char helpers.
+ */
+static Char STRdotexe[] = { '.', 'e', 'x', 'e', '\0' };
+
+static Char *
+dotexe_variant(Char *sf)
+{
+    size_t l = Strlen(sf);
+
+    /* already ".exe" (case-insensitive) -> no retry */
+    if (l >= 4 &&
+	sf[l - 4] == '.' &&
+	(sf[l - 3] == 'e' || sf[l - 3] == 'E') &&
+	(sf[l - 2] == 'x' || sf[l - 2] == 'X') &&
+	(sf[l - 1] == 'e' || sf[l - 1] == 'E'))
+	return NULL;
+    return Strspl(sf, STRdotexe);
+}
+#endif /* __COSMOCC__ */
